{
  "name": "snippethub-cli",
  "version": "1.0.0",
  "description": "🚀 A powerful CLI tool for managing code snippets with full-text search, syntax highlighting, and tag management",
  "main": "dist/index.js",
  "bin": {
    "snippethub": "dist/index.js",
    "snip": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "code-snippets",
    "cli-tool",
    "developer-tools",
    "snippet-manager",
    "productivity",
    "code-storage",
    "syntax-highlighting"
  ],
  "author": "Lobster Dev Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/snippethub-cli.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/snippethub-cli/issues"
  },
  "homepage": "https://github.com/yourusername/snippethub-cli#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.9.0",
    "fs-extra": "^11.2.0",
    "uuid": "^9.0.1",
    "clipboardy": "^2.3.0",
    "ora": "^5.4.1",
    "boxen": "^5.1.2",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/inquirer": "^8.2.10",
    "@types/fs-extra": "^11.0.4",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10"
  }
}
